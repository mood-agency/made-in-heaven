{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:worker": {
      "cache": false,
      "persistent": true
    },
    "deploy": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "types": {
      "cache": false,
      "outputs": ["worker-configuration.d.ts"]
    },
    "db:generate": {
      "cache": false,
      "outputs": ["drizzle/migrations/**"]
    },
    "db:migrate": {
      "cache": false
    },
    "db:migrate:local": {
      "cache": false
    },
    "db:migrate:remote": {
      "cache": false
    }
  }
}
