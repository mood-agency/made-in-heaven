{
  "name": "@mih/server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch index.node.ts",
    "dev:worker": "wrangler dev",
    "deploy": "CI=true wrangler deploy",
    "types": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:local": "wrangler d1 migrations apply made-in-heaven --local",
    "db:migrate:remote": "wrangler d1 migrations apply made-in-heaven --remote",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@cloudflare/playwright": "^1.3.0",
    "@hono/node-server": "^1.13.8",
    "@hono/zod-validator": "^0.4.3",
    "@jsquash/png": "^3.1.1",
    "@libsql/client": "^0.14.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.7.10",
    "node-cron": "^3.0.3",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "ws": "^8.20.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250422.0",
    "@types/node": "^22.15.3",
    "@types/node-cron": "^3.0.11",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.30.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "wrangler": "^4.0.0"
  }
